@{
    ViewData["Title"] = "Регистрация";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center py-4"
     style="background:#f9f7fd;">
    <div class="card shadow p-4" style="width:100%; max-width:440px;">
        <h3 class="text-center mb-1">Регистрация</h3>
        <p class="text-center text-muted small mb-4">
            Създайте акаунт и започнете своя здравословен път.
        </p>

        <form asp-controller="Account" asp-action="Register" method="post">
            <div class="mb-3">
                <label class="form-label">Потребителско име</label>
                <input name="username" type="text" class="form-control"
                       placeholder="Потребителско ви" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input name="email" type="email" class="form-control"
                       placeholder="you@example.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Парола</label>
                <input name="password" type="password" class="form-control"
                       placeholder="Поне 6 символа" required minlength="6" />
            </div>
            <div class="mb-4">
                <label class="form-label">Потвърди парола</label>
                <input name="confirmPassword" type="password" class="form-control"
                       placeholder="Повторете паролата" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Регистрация</button>
        </form>

        <p class="text-center mt-3 small">
            Вече имате акаунт?
            <a asp-controller="Account" asp-action="Login">Влезте тук</a>
        </p>
    </div>
</div>