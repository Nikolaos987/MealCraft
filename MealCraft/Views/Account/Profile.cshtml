@model MealCraft.Models.ProfileViewModel
@{
    ViewData["Title"] = "Моят профил";
}

<div class="container py-5">
    <div class="card shadow-sm mx-auto p-4" style="max-width: 720px;">

        <div class="mb-4">
            <h2 class="fw-bold mb-1">Твоят здравен профил</h2>
            <p class="text-muted">
                Попълнете профила си, за да получите персонализирани препоръки
                съобразени с вашите цели.
            </p>
        </div>

        <form asp-controller="Account" asp-action="Profile"
              method="post" novalidate>
            @Html.AntiForgeryToken()

            <!-- Basic info -->
            <h5 class="fw-semibold border-bottom pb-2 mb-3">Основна информация</h5>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label asp-for="Age" class="form-label">Възраст</label>
                    <input asp-for="Age" type="number" class="form-control" />
                    <span asp-validation-for="Age" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Gender" class="form-label">Пол</label>
                    <select asp-for="Gender" class="form-select">
                        <option value="">Избери пол</option>
                        <option value="male">Мъж</option>
                        <option value="female">Жена</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label asp-for="Weight" class="form-label">Тегло (кг)</label>
                    <input asp-for="Weight" type="number" step="0.1"
                           class="form-control" />
                    <span asp-validation-for="Weight" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Height" class="form-label">Височина (см)</label>
                    <input asp-for="Height" type="number" class="form-control" />
                    <span asp-validation-for="Height" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="ActivityLevel" class="form-label">
                    Ниво на физическа активност
                </label>
                <select asp-for="ActivityLevel" class="form-select">
                    <option value="">Изберете ниво на активност</option>
                    <option value="sedentary">Заседнал</option>
                    <option value="light">Леко активен</option>
                    <option value="active">Активен</option>
                    <option value="very_active">Изключително активен</option>
                </select>
                <span asp-validation-for="ActivityLevel" class="text-danger small"></span>
            </div>

            <!-- Dietary preferences -->
            <h5 class="fw-semibold border-bottom pb-2 mb-3">Диетични предпочитания</h5>
            <div class="row g-2 mb-4">
                @foreach (var (prop, label) in new[] {
                    ("NoRestrictions", "Без ограничения"),
                    ("Vegetarian",     "Вегетарианец"),
                    ("Vegan",          "Веган"),
                    ("Pescatarian",    "Пескетарианец"),
                    ("Keto",           "Кетогенна"),
                    ("Paleo",          "Палео")
                })
                {
                    <div class="col-6 col-sm-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   name="@prop" id="@prop" />
                            <label class="form-check-label" for="@prop">@label</label>
                        </div>
                    </div>
                }
            </div>

            <!-- Goals -->
            <h5 class="fw-semibold border-bottom pb-2 mb-3">Здравни цели</h5>
            <div class="row g-2 mb-4">
                @foreach (var (prop, label) in new[] {
                    ("WeightLoss",     "Отслабване"),
                    ("WeightGain",     "Качване на тегло"),
                    ("MaintainWeight", "Поддържане на тегло"),
                    ("BuildMuscle",    "Изграждане на мускули"),
                    ("ImproveHealth",  "Подобряване на здравето")
                })
                {
                    <div class="col-6 col-sm-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   name="@prop" id="@prop" />
                            <label class="form-check-label" for="@prop">@label</label>
                        </div>
                    </div>
                }
            </div>

            <!-- Allergies + restrictions -->
            <h5 class="fw-semibold border-bottom pb-2 mb-3">Здравословна информация</h5>

            <div class="mb-3">
                <label asp-for="Allergies" class="form-label">Алергии</label>
                <textarea asp-for="Allergies" class="form-control" rows="2"
                          placeholder="ядки, глутен, лактоза..."></textarea>
                <div class="form-text">Разделени със запетая</div>
            </div>

            <div class="mb-4">
                <label asp-for="HealthRestrictions" class="form-label">
                    Здравословни ограничения
                </label>
                <textarea asp-for="HealthRestrictions" class="form-control" rows="2"
                          placeholder="диабет, хипертония..."></textarea>
                <div class="form-text">Разделени със запетая</div>
            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-end gap-2">
                <a asp-controller="Home" asp-action="Index"
                   class="btn btn-outline-secondary px-4">Отказ</a>
                <button type="submit" class="btn btn-success px-4">
                    Запази профил
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}